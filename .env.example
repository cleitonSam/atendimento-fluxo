# =============================================
# Banco de dados PostgreSQL (externo)
# Atenção: caracteres especiais na senha (@, #, !) devem ser URL-encoded
#   @ → %40   # → %23   ! → %21
# Exemplo: postgresql+asyncpg://user:senha%40segura@host:5432/db
# =============================================
DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/banco?sslmode=disable

# =============================================
# Redis (externo)
# =============================================
REDIS_URL=redis://:senha@host:6379

# =============================================
# Autenticação JWT
# =============================================
# Gere com: openssl rand -hex 32
JWT_SECRET_KEY=troque_esta_chave_secreta

# =============================================
# APIs de IA
# =============================================
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# =============================================
# Chatwoot
# =============================================
CHATWOOT_URL=https://app.chatwoot.com
CHATWOOT_TOKEN=
CHATWOOT_WEBHOOK_SECRET=
